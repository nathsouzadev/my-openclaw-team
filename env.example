# Copy to .env and fill in. (.env is dotfile-blocked from this tool, copy manually.)

# Gateway
GATEWAY_PORT=5010

# Agent 1 identity (OpenClaw side)
AGENT_1_ID=main
AGENT_1_NAME=Alice
AGENT_1_ACCOUNT_ID=alice

# Agent 1 Slack app credentials (Socket Mode)
AGENT_1_SLACK_BOT_TOKEN=xoxb-REPLACE-ME
AGENT_1_SLACK_APP_TOKEN=xapp-REPLACE-ME

# Agent 2 identity (OpenClaw side)
AGENT_2_ID=agent-2
AGENT_2_NAME=Bob
AGENT_2_ACCOUNT_ID=bob

# Agent 2 Slack app credentials (Socket Mode)
AGENT_2_SLACK_BOT_TOKEN=xoxb-REPLACE-ME
AGENT_2_SLACK_APP_TOKEN=xapp-REPLACE-ME

# Shared Slack channel ID where both bots may speak (use C... id, not #name)
SLACK_CHANNEL_ID=C0000000000
